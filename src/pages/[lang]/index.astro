---
import Layout from '../../layouts/Layout.astro';
import { useTranslations, allLangs, type Lang } from '../../i18n/utils';
import { getSlugGroups, resolveGroupEntry } from '../../lib/posts';

export function getStaticPaths() {
  return allLangs.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const groups = await getSlugGroups('blog');
const latest = groups
  .map((group) => ({ group, ...resolveGroupEntry(group, lang) }))
  .sort((a, b) => b.entry.data.pubDate.valueOf() - a.entry.data.pubDate.valueOf())
  .slice(0, 5);
---

<Layout lang={lang} title="madhellequin">
  <h1>madhellequin</h1>
  <h2>{t('nav.blog')}</h2>
  {latest.length === 0 && <p>{t('blog.empty')}</p>}
  <ul>
    {
      latest.map(({ group, contentLang, entry }) => (
        <li>
          <a href={`/${lang}/blog/${group.slug}/${contentLang}/`}>{entry.data.title}</a>
        </li>
      ))
    }
  </ul>
</Layout>
