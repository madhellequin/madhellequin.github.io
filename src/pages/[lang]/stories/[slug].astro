---
import Layout from '../../../layouts/Layout.astro';
import type { Lang } from '../../../i18n/utils';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const stories = await getCollection('stories');

  // Group by the language-less slug so each page knows which other
  // locales actually have a translation of this same story.
  const langsBySlug = new Map<string, Lang[]>();
  for (const story of stories) {
    const [lang, ...rest] = story.id.split('/');
    const slug = rest.join('/');
    langsBySlug.set(slug, [...(langsBySlug.get(slug) ?? []), lang as Lang]);
  }

  return stories.map((story) => {
    const [lang, ...rest] = story.id.split('/');
    const slug = rest.join('/');
    return {
      params: { lang, slug },
      props: { story, availableLangs: langsBySlug.get(slug) ?? [lang as Lang] },
    };
  });
}

interface Props {
  story: CollectionEntry<'stories'>;
  availableLangs: Lang[];
}

const { lang } = Astro.params as { lang: Lang };
const { story, availableLangs } = Astro.props;
const { Content } = await render(story);
---

<Layout
  lang={lang}
  title={story.data.title}
  description={story.data.description}
  availableLangs={availableLangs}
>
  <article>
    <h1>{story.data.title}</h1>
    <p>
      <time datetime={story.data.pubDate.toISOString()}>
        {story.data.pubDate.toLocaleDateString(lang)}
      </time>
    </p>
    {story.data.image && <img src={story.data.image} alt="" />}
    <Content />
  </article>
</Layout>
