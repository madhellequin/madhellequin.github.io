---
import Layout from '../../../../layouts/Layout.astro';
import { languages, useTranslations, allLangs, type Lang } from '../../../../i18n/utils';
import { getSlugGroups } from '../../../../lib/posts';
import { render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const groups = await getSlugGroups('blog');
  return groups.flatMap((group) =>
    allLangs.flatMap((siteLang) =>
      group.availableLangs.map((contentLang) => ({
        params: { lang: siteLang, slug: group.slug, contentLang },
        props: { post: group.entries.get(contentLang)!, availableLangs: group.availableLangs },
      })),
    ),
  );
}

interface Props {
  post: CollectionEntry<'blog'>;
  availableLangs: Lang[];
}

const { lang, slug, contentLang } = Astro.params as { lang: Lang; slug: string; contentLang: Lang };
const { post, availableLangs } = Astro.props;
const { Content } = await render(post);
const t = useTranslations(lang);
---

<Layout lang={lang} title={post.data.title} description={post.data.description}>
  <article>
    <h1>{post.data.title}</h1>
    <p>
      <time datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString(contentLang)}
      </time>
    </p>
    {
      availableLangs.length > 1 && (
        <div class="content-langs">
          <span>{t('content.readIn')}:</span>
          {availableLangs.map((l) =>
            l === contentLang ? (
              <span class="current">{languages[l]}</span>
            ) : (
              <a href={`/${lang}/blog/${slug}/${l}/`}>{languages[l]}</a>
            ),
          )}
        </div>
      )
    }
    {post.data.image && <img src={post.data.image} alt="" />}
    <Content />
  </article>
</Layout>
