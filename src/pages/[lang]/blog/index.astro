---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations, type Lang } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return (['ru', 'uk', 'en'] as const).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const posts = (await getCollection('blog', ({ data }) => data.lang === lang && !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout lang={lang} title={t('nav.blog')}>
  <h1>{t('nav.blog')}</h1>
  {posts.length === 0 && <p>{t('blog.empty')}</p>}
  <ul>
    {
      posts.map((post) => {
        const slug = post.id.split('/').slice(1).join('/');
        return (
          <li>
            <a href={`/${lang}/blog/${slug}/`}>{post.data.title}</a>
            <p>{post.data.description}</p>
          </li>
        );
      })
    }
  </ul>
</Layout>
