---
import { languages, useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  // Explicit per-locale links for the language switcher, used on detail pages
  // where the translated entry has a different slug. Falls back to swapping
  // the locale segment of the current URL.
  switcherLinks?: Partial<Record<Lang, string>>;
}

const { lang, title, description = '', switcherLinks } = Astro.props;
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
const restOfPath = currentPath.replace(/^\/(ru|uk|en)/, '') || '/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={`/${lang}/`}>madhellequin</a>
      <nav class="site-nav">
        <a href={`/${lang}/`}>{t('nav.home')}</a>
        <a href={`/${lang}/blog/`}>{t('nav.blog')}</a>
        <a href={`/${lang}/stories/`}>{t('nav.stories')}</a>
        <a href={`/${lang}/about/`}>{t('nav.about')}</a>
      </nav>
      <div class="lang-switcher">
        {Object.entries(languages).map(([code, label]) => (
          <a
            href={switcherLinks?.[code as Lang] ?? `/${code}${restOfPath}`}
            aria-current={code === lang ? 'page' : undefined}
          >
            {label}
          </a>
        ))}
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} madhellequin</p>
    </footer>
    <style>
      .site-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 3rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
      }
      .brand {
        font-family: var(--font-mono);
        font-weight: 700;
        letter-spacing: 0.04em;
        color: var(--text);
        text-decoration: none;
      }
      .brand:hover {
        color: var(--accent);
        text-decoration: none;
      }
      .site-nav {
        display: flex;
        gap: 1.25rem;
      }
      .site-nav a {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-muted);
        text-decoration: none;
      }
      .site-nav a:hover {
        color: var(--accent);
        text-decoration: none;
        text-shadow: 0 0 8px var(--glow);
      }
      .lang-switcher {
        display: flex;
        gap: 0.4rem;
      }
      .lang-switcher a {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        padding: 0.2rem 0.55rem;
        border: 1px solid var(--border);
        border-radius: 3px;
        color: var(--text-muted);
        text-decoration: none;
      }
      .lang-switcher a:hover {
        color: var(--text);
        border-color: var(--accent);
        text-decoration: none;
      }
      .lang-switcher a[aria-current='page'] {
        color: var(--accent);
        border-color: var(--accent);
        box-shadow: 0 0 8px var(--glow);
      }
      .site-footer {
        margin-top: 4rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        font-family: var(--font-mono);
        color: var(--text-muted);
        font-size: 0.8rem;
      }
    </style>
    <style is:global>
      :root {
        --bg: #0a0e17;
        --bg-elevated: #10182b;
        --text: #cdd9ec;
        --text-muted: #7c8aa8;
        --accent: #3ee6d8;
        --accent-secondary: #b586ff;
        --border: #223055;
        --glow: rgba(62, 230, 216, 0.35);
        --font-sans:
          system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        --font-mono:
          ui-monospace, SFMono-Regular, Menlo, Consolas, 'Liberation Mono', monospace;
      }

      html {
        color-scheme: dark;
      }

      body {
        max-width: 720px;
        margin: 0 auto;
        padding: 1rem;
        font-family: var(--font-sans);
        line-height: 1.6;
        color: var(--text);
        background-color: var(--bg);
        background-image:
          radial-gradient(circle at 15% 10%, rgba(62, 230, 216, 0.07), transparent 35%),
          radial-gradient(circle at 85% 70%, rgba(181, 134, 255, 0.06), transparent 40%);
        background-attachment: fixed;
        min-height: 100vh;
      }

      h1,
      h2,
      h3 {
        font-family: var(--font-mono);
        letter-spacing: 0.01em;
        color: var(--text);
      }

      article h1 {
        color: var(--accent);
        border-bottom: 1px solid var(--border);
        padding-bottom: 0.6rem;
      }

      a {
        color: var(--accent);
      }

      a:hover {
        text-decoration: underline;
      }

      time {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--text-muted);
      }

      main ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
      }

      main ul li {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-left: 3px solid var(--accent-secondary);
        border-radius: 4px;
        padding: 0.9rem 1.1rem;
        transition:
          border-color 0.15s ease,
          transform 0.15s ease;
      }

      main ul li:hover {
        border-color: var(--accent);
        transform: translateX(2px);
      }

      main ul li a {
        font-family: var(--font-mono);
        font-weight: 700;
        text-decoration: none;
      }

      main ul li p {
        margin: 0.35rem 0 0;
        color: var(--text-muted);
        font-size: 0.95rem;
      }

      table {
        border-collapse: collapse;
        width: 100%;
        background: var(--bg-elevated);
      }

      table th,
      table td {
        border: 1px solid var(--border);
        padding: 0.5rem 0.7rem;
        text-align: left;
      }

      table th {
        font-family: var(--font-mono);
        color: var(--accent);
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.04em;
      }

      img {
        max-width: 100%;
        height: auto;
        border-radius: 4px;
        border: 1px solid var(--border);
      }
    </style>
  </body>
</html>
