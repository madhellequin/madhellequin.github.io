---
import '../styles/global.css';
import { languages, useTranslations, LANG_STORAGE_KEY, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  // Languages this exact page has a translation for. Omit when the page
  // exists in all locales (listing pages, about); pass it on post/story
  // detail pages, where a translation may not exist yet, so the switcher
  // can disable the missing ones instead of linking to a 404.
  availableLangs?: Lang[];
}

const { lang, title, description = '', availableLangs } = Astro.props;
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
const restOfPath = currentPath.replace(/^\/(ru|uk|en)/, '') || '/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={`/${lang}/`}>madhellequin</a>
      <nav class="site-nav">
        <a href={`/${lang}/`}>{t('nav.home')}</a>
        <a href={`/${lang}/blog/`}>{t('nav.blog')}</a>
        <a href={`/${lang}/stories/`}>{t('nav.stories')}</a>
        <a href={`/${lang}/about/`}>{t('nav.about')}</a>
      </nav>
      <div class="lang-switcher">
        {Object.entries(languages).map(([code, label]) =>
          !availableLangs || availableLangs.includes(code as Lang) ? (
            <a href={`/${code}${restOfPath}`} aria-current={code === lang ? 'page' : undefined}>
              {label}
            </a>
          ) : (
            <span class="lang-disabled" title={t('lang.notTranslated')}>
              {label}
            </span>
          ),
        )}
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} madhellequin</p>
    </footer>
    <script define:vars={{ lang, storageKey: LANG_STORAGE_KEY }}>
      localStorage.setItem(storageKey, lang);
    </script>
    <style>
      .site-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 3rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
      }
      .brand {
        font-family: var(--font-mono);
        font-weight: 700;
        letter-spacing: 0.04em;
        color: var(--text);
        text-decoration: none;
      }
      .brand:hover {
        color: var(--accent);
        text-decoration: none;
      }
      .site-nav {
        display: flex;
        gap: 1.25rem;
      }
      .site-nav a {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-muted);
        text-decoration: none;
      }
      .site-nav a:hover {
        color: var(--accent);
        text-decoration: none;
        text-shadow: 0 0 8px var(--glow);
      }
      .lang-switcher {
        display: flex;
        gap: 0.4rem;
      }
      .lang-switcher a {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        padding: 0.2rem 0.55rem;
        border: 1px solid var(--border);
        border-radius: 3px;
        color: var(--text-muted);
        text-decoration: none;
      }
      .lang-switcher a:hover {
        color: var(--text);
        border-color: var(--accent);
        text-decoration: none;
      }
      .lang-switcher a[aria-current='page'] {
        color: var(--accent);
        border-color: var(--accent);
        box-shadow: 0 0 8px var(--glow);
      }
      .lang-switcher .lang-disabled {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        padding: 0.2rem 0.55rem;
        border: 1px dashed var(--border);
        border-radius: 3px;
        color: var(--text-muted);
        opacity: 0.4;
        cursor: not-allowed;
      }
      .site-footer {
        margin-top: 4rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        font-family: var(--font-mono);
        color: var(--text-muted);
        font-size: 0.8rem;
      }
    </style>
  </body>
</html>
